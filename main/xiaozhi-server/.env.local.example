# 复制为 .env 后修改：cp .env.local.example .env

# ---------- 镜像（与 docker-build-local.sh 输出一致）----------
DOCKER_IMAGE_SERVER=xiaozhi-local/xiaozhi-esp32-server:latest
DOCKER_IMAGE_WEB=xiaozhi-local/xiaozhi-esp32-server-web:latest

# ---------- 端口 ----------
SERVER_WS_PORT=8000
SERVER_HTTP_PORT=8003
WEB_PORT=8002
TZ=Asia/Shanghai

# ---------- MySQL（已有容器，端口映射到宿主机）----------
MYSQL_HOST=host.docker.internal
MYSQL_PORT=3306
MYSQL_DATABASE=xiaozhi_esp32_server
MYSQL_USER=root
MYSQL_PASSWORD=12345678

# ---------- Redis（已有容器，端口映射到宿主机）----------
REDIS_HOST=host.docker.internal
REDIS_PORT=6379
REDIS_PASSWORD=

# ---------- 可选：与 MySQL/Redis 共用 Docker 网络 ----------
# 若不想走 host 端口，可将两个服务接入同一网络，并把 HOST 改为容器名：
#   docker network create xiaozhi-infra
#   docker network connect xiaozhi-infra <mysql容器名>
#   docker network connect xiaozhi-infra <redis容器名>
#   docker network connect xiaozhi-infra xiaozhi-esp32-server-web
# 然后设置：MYSQL_HOST=<mysql容器名>  REDIS_HOST=<redis容器名>
